{"@class": "com.nd.elearning.sdk.resource.gateway.v5.bean.question.QuestionVo", "original_type": 4, "original_sub_type": "questions", "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "id": "1e7f0160-db7c-4ae0-a5d4-648063d6db3e", "type": 201, "content": {"preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/1e7f0160-db7c-4ae0-a5d4-648063d6db3e@1.pkg/1772597538971/mainbig.xml.jpg?v=1772597539360", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/1e7f0160-db7c-4ae0-a5d4-648063d6db3e@1.pkg/1772597538971/mainbig.xml.jpg?v=1772597539360"}, "identifier": "1e7f0160-db7c-4ae0-a5d4-648063d6db3e", "test_cases": "", "feedbacks": [{"identifier": "showAnswer", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<div><p style=\"background: #FFFFFF;text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">本题考查对在实践中学习的理解。</span></p><p style=\"background: #FFFFFF;text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">B：题干中学校布置的乡村研学、科学实验等实践作业，让学生在具体活动中提升协作能力和解决问题的能力，体现了在实践中学习对提升综合素养的作用，故 B 符合题意；</span></p><p style=\"background: #FFFFFF;text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">A：题干强调的是实践学习，而非 &ldquo;专注课本知识&rdquo;，故 A 不符合题意；</span></p><p style=\"background: #FFFFFF;text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">C：作业未涉及职业目标和生涯规划，故 C 不符合题意；</span></p><p style=\"background: #FFFFFF;text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">D：材料未体现 &ldquo;竞争意识&rdquo;，重点是实践带来的成长，故 D 不符合题意；</span></p><p style=\"text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">故本题选 B。</span></p></div>"}, {"identifier": "showHint", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": ""}], "sequnce_number": 1, "description": "<div><p style=\"text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">（改编）2025年暑假，</span><span style=\"background: #FFFFFF;color: #404040;\">某校布置了一份&ldquo;特别&rdquo;的假期作业：参加一次社区公益活动、完成一次社会调查、在家学做几道家常菜</span><span style=\"background: #FFFFFF;color: #404040;\">&hellip;&hellip;</span><span style=\"background: #FFFFFF;color: #404040;\">这份作业旨在引导学生（ &nbsp; &nbsp;</span><span style=\"background: #FFFFFF;color: #404040;\">）</span></p></div>", "label": "", "title": "（改编）2025年暑假，某校布置了一份“特别”的假期作业：参加一次社区公益活动、完成一次社会调查、在家学做几道家常菜……这份作业旨在引导学生（    ）", "res_type": "$RE0201", "adaptive": false, "timer": {}, "time_dependent": false, "examples": {"responses": [], "feedbacks": [], "items": []}, "responses": [{"identifier": "RESPONSE_1-1", "sequence": "1-1", "base_type": "identifier", "cardinality": "single", "corrects": ["B"]}], "location": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/1e7f0160-db7c-4ae0-a5d4-648063d6db3e@1.pkg/item.json?v=1754984658580", "lang": "", "items": [{"min_choices": 0, "evaluate_result_show": false, "attachments": [], "columns": 1, "type": "choice", "choices_list": [], "associable_hotspots": [], "subtype": "", "children": [], "hide_answer_area": false, "options": [], "orientation": 0, "multiple": false, "raw": false, "titles": [], "rows": 1, "response_identifier": "RESPONSE_1-1", "sequence": "0", "max_choices": 1, "gap_imgs": [], "shuffle": false, "choices": [{"identifier": "A", "correct": false, "match_max": 0, "group_id": "", "fixed": true, "text": "<div><p style=\"text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">专注课本知识，提高学习成绩</span></p></div>"}, {"identifier": "B", "correct": false, "match_max": 0, "group_id": "", "fixed": true, "text": "<div><p style=\"text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">在实践中学习，提升综合素养</span></p></div>"}, {"identifier": "C", "correct": false, "match_max": 0, "group_id": "", "fixed": true, "text": "<div><p style=\"text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">明确职业目标，规划职业生涯</span></p></div>"}, {"identifier": "