itles": [], "rows": 1, "response_identifier": "RESPONSE_1-1", "sequence": "0", "max_choices": 1, "gap_imgs": [], "choice_type": "character", "shuffle": false, "choices": [{"identifier": "A", "correct": false, "match_max": 0, "group_id": "", "fixed": true, "text": "<div><p style=\"text-align: justify;\"><span>北</span><span class=\"dot\">冥</span><span>有鱼，其名为鲲 &nbsp; &nbsp;南</span><span class=\"dot\">冥</span><span>者，天池也</span></p></div>"}, {"identifier": "B", "correct": false, "match_max": 0, "group_id": "", "fixed": true, "text": "<div><p style=\"text-align: justify;\"><span>去</span><span class=\"dot\">以</span><span>六月息者也 &nbsp; &nbsp;生物之</span><span class=\"dot\">以</span><span>息相吹也</span></p></div>"}, {"identifier": "C", "correct": false, "match_max": 0, "group_id": "", "fixed": true, "text": "<div><p style=\"text-align: justify;\"><span>天之苍苍，</span><span class=\"dot\">其</span><span>正色邪 &nbsp; &nbsp;</span><span class=\"dot\">其</span><span>视下也</span></p></div>"}, {"identifier": "D", "correct": false, "match_max": 0, "group_id": "", "fixed": true, "text": "<div><p style=\"text-align: justify;\"><span>其名</span><span class=\"dot\">为</span><span>鲲 &nbsp; &nbsp;化而</span><span class=\"dot\">为</span><span>鸟</span></p></div>"}], "prompt": "<div><p style=\"text-align: justify;\"><A id=\"_Hlk169710853\" style=\"text-decoration: none;\"></A><span>下列句子中加点词意思或用法相同的一项是</span><span>（　　）</span></p></div>", "object": {"data": "", "width": "1000", "type": "image/png", "params": {"originalImage": "", "blankImage": ""}, "height": "600"}}], "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878"}, "source": {"container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "tags": ["$M002000000", "ff8080814371757b014390fcdce504bd", "$RE0000", "$M003002000", "$RE0200", "$RE0201", "e7bbce2c-0590-11ed-9c79-92fc3b3249d5", "44bee8bc-54e6-11ed-9c34-850ba61fa9f4", "6a749654-0772-11ed-ac74-092ab92074e6", "5136342960", "44bec67a-54e6-11ed-9c34-850ba61f