{"@class": "com.nd.elearning.sdk.resource.gateway.v5.bean.question.QuestionVo", "original_type": 4, "original_sub_type": "questions", "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "id": "bc9171c6-95b9-41de-9b00-78e85ff0ac6b", "type": 201, "content": {"preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/bc9171c6-95b9-41de-9b00-78e85ff0ac6b@3.pkg/1772595180038/mainbig.xml.jpg?v=1772595180954", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/bc9171c6-95b9-41de-9b00-78e85ff0ac6b@3.pkg/1772595180038/mainbig.xml.jpg?v=1772595180954"}, "identifier": "bc9171c6-95b9-41de-9b00-78e85ff0ac6b", "feedbacks": [{"identifier": "showHint", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": ""}, {"identifier": "showAnswer", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<p>联系课文《在牛肚子里旅行》</p>\n"}], "sequnce_number": 1, "description": "<p>对课文内容的理解正确的一项是（&nbsp; &nbsp;）。</p>\n", "title": "对课文内容的理解正确的一项是（   ）。", "res_type": "$RE0201", "adaptive": false, "timer": {"timer_type": "sequence"}, "time_dependent": false, "responses": [{"identifier": "RESPONSE_1-1", "sequence": "1-1", "base_type": "identifier", "cardinality": "single", "corrects": ["D"]}], "location": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/bc9171c6-95b9-41de-9b00-78e85ff0ac6b@3.pkg/item.json?v=1747530076086", "items": [{"min_choices": 0, "attachments": [], "columns": 1, "type": "choice", "choices_list": [], "associable_hotspots": [], "children": [], "hide_answer_area": false, "options": [], "orientation": 0, "multiple": false, "raw": false, "titles": [], "rows": 1, "response_identifier": "RESPONSE_1-1", "sequence": "0", "max_choices": 1, "gap_imgs": [], "choice_type": "character", "shuffle": false, "choices": [{"identifier": "A", "correct": false, "match_max": 1, "group_id": "", "fixed": false, "text": "<p>牛肚子里一共有四个胃，有三个胃是管消化的。</p>\n"}, {"identi