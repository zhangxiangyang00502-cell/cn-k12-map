{"@class": "com.nd.elearning.sdk.resource.gateway.v5.bean.question.QuestionVo", "original_type": 4, "original_sub_type": "questions", "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "id": "c647d28f-bbb2-4608-ad28-b24741545658", "type": 201, "content": {"preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/c647d28f-bbb2-4608-ad28-b24741545658@1.pkg/1772602440905/mainbig.xml.jpg?v=1772602441771", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/c647d28f-bbb2-4608-ad28-b24741545658@1.pkg/1772602440905/mainbig.xml.jpg?v=1772602441771"}, "identifier": "c647d28f-bbb2-4608-ad28-b24741545658", "feedbacks": [{"identifier": "showHint", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": ""}, {"identifier": "showAnswer", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<p>A.长虹饮间（涧）；B.洨河（xiáo）；C.记载（zăi），推崇（chóng）</p>\n"}], "sequnce_number": 1, "description": "<p>下列词语中字音、字形完全正确的一项是（　　）</p>\n", "title": "下列词语中字音、字形完全正确的一项是（　　）", "res_type": "$RE0201", "adaptive": false, "timer": {"timer_type": "sequence"}, "time_dependent": false, "responses": [{"identifier": "RESPONSE_1-1", "sequence": "1-1", "base_type": "identifier", "cardinality": "single", "corrects": ["D"]}], "location": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/c647d28f-bbb2-4608-ad28-b24741545658@1.pkg/item.json?v=1751204910036", "items": [{"min_choices": 0, "attachments": [], "columns": 1, "type": "choice", "choices_list": [], "associable_hotspots": [], "children": [], "hide_answer_area": false, "options": [], "orientation": 0, "multiple": false, "raw": false, "titles": [], "rows": 1, "response_identifier": "RESPONSE_1-1", "sequence": "0", "max_choices": 1, "gap_imgs": [], "choice_type": "character", "shuffle": false, "choices": [{"identifier": "A", "correct": false, "match_max": 1, "group_id": "", "fixed": false, "text": "<p>和谐（xié） &nbsp;&nbs