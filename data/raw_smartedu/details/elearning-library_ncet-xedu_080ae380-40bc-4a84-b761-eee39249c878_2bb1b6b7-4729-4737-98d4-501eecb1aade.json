{"@class": "com.nd.elearning.sdk.resource.gateway.v5.bean.question.QuestionVo", "original_type": 4, "original_sub_type": "questions", "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "id": "2bb1b6b7-4729-4737-98d4-501eecb1aade", "type": 201, "content": {"preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/2bb1b6b7-4729-4737-98d4-501eecb1aade@3.pkg/1772595129775/mainbig.xml.jpg?v=1772595130735", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/2bb1b6b7-4729-4737-98d4-501eecb1aade@3.pkg/1772595129775/mainbig.xml.jpg?v=1772595130735"}, "identifier": "2bb1b6b7-4729-4737-98d4-501eecb1aade", "feedbacks": [{"identifier": "showHint", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": ""}, {"identifier": "showAnswer", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<p>联系上下文</p>\n"}], "sequnce_number": 1, "description": "<p>下列句子中，体现了作者心情沮丧的一项是（&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;）</p>\n", "title": "下列句子中，体现了作者心情沮丧的一项是（       ）", "res_type": "$RE0201", "adaptive": false, "timer": {"timer_type": "sequence"}, "time_dependent": false, "responses": [{"identifier": "RESPONSE_1-1", "sequence": "1-1", "base_type": "identifier", "cardinality": "single", "corrects": ["C"]}], "location": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/2bb1b6b7-4729-4737-98d4-501eecb1aade@3.pkg/item.json?v=1753276349770", "items": [{"min_choices": 0, "attachments": [], "columns": 1, "type": "choice", "choices_list": [], "associable_hotspots": [], "children": [], "hide_answer_area": false, "options": [], "orientation": 0, "multiple": false, "raw": false, "titles": [], "rows": 1, "response_identifier": "RESPONSE_1-1", "sequence": "0", "max_choices": 1, "gap_imgs": [], "choice_type": "character", "shuffle": false, "choices": [{"identifier": "A", "correct": false, "match_max": 1, "group_id": "", "fixed": false, "text": "<p>虽然它远不如