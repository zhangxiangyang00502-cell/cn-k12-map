{"@class": "com.nd.elearning.sdk.resource.gateway.v5.bean.question.QuestionVo", "original_type": 4, "original_sub_type": "questions", "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "id": "57547387-7216-4f2d-9f59-4bede801aae3", "type": 201, "content": {"preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/57547387-7216-4f2d-9f59-4bede801aae3@4.pkg/1772602024782/mainbig.xml.jpg?v=1772602025789", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/57547387-7216-4f2d-9f59-4bede801aae3@4.pkg/1772602024782/mainbig.xml.jpg?v=1772602025789"}, "identifier": "57547387-7216-4f2d-9f59-4bede801aae3", "feedbacks": [{"identifier": "showHint", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": ""}, {"identifier": "showAnswer", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<div>\n<p style=\"text-align: justify;\"><span>B.</span><span>行将就木”的意思是快要进棺材了，指人临近死亡，用在此处不合语境。</span></p>\n</div>\n"}], "sequnce_number": 1, "description": "<div>\n<p style=\"text-align: justify;\"><span>下列句子中，加点的成语使用不正确的一项是( &nbsp; &nbsp;)</span></p>\n</div>\n", "label": "", "title": "下列句子中，加点的成语使用不正确的一项是(    )", "res_type": "$RE0201", "adaptive": false, "timer": {"timer_type": "sequence"}, "time_dependent": false, "responses": [{"identifier": "RESPONSE_1-1", "sequence": "1-1", "base_type": "identifier", "cardinality": "single", "corrects": ["B"]}], "location": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/57547387-7216-4f2d-9f59-4bede801aae3@4.pkg/item.json?v=1754971997947", "lang": "", "items": [{"min_choices": 0, "evaluate_result_show": false, "attachments": [], "columns": 1, "type": "choice", "choices_list": [], "associable_hotspots": [], "subtype": "", "children": [], "hide_answer_area": false, "options": [], "orientation": 0, "multiple": false, "raw": false, "titles": [], "rows": 1, "response_identifier": "RESPONSE_1-1", "sequence":