{"@class": "com.nd.elearning.sdk.resource.gateway.v5.bean.question.QuestionVo", "original_type": 4, "original_sub_type": "questions", "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "id": "fc9426fd-8bfa-42e6-98fe-d8345bb0aa63", "type": 201, "content": {"preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/fc9426fd-8bfa-42e6-98fe-d8345bb0aa63@2.pkg/1772602337511/mainbig.xml.jpg?v=1772602338275", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/fc9426fd-8bfa-42e6-98fe-d8345bb0aa63@2.pkg/1772602337511/mainbig.xml.jpg?v=1772602338275"}, "identifier": "fc9426fd-8bfa-42e6-98fe-d8345bb0aa63", "test_cases": "", "feedbacks": [{"identifier": "showHint", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": ""}, {"identifier": "showAnswer", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<p style=\"text-align: justify;\">A 选项：“非 / 宁静 / 无以 / 致远”，意思是不宁静专一就无法达到远大目标。节奏划分合理。</p>\n\n<ul>\n\t<li>B 选项：“夫 / 君子 / 之行，静以 / 修身” 节奏划分错误，正确的划分应为 “夫 / 君子之行，静 / 以修身”。“夫” 是句首发语词，后面应停顿；“君子之行” 是一个整体，指君子的行为操守；“静以修身” 意思是依靠内心安静来修养身心，“静” 是方式，“以修身” 是目的，中间应停顿。</li>\n\t<li>C 选项：“险躁 / 则 / 不能 / 冶性”，意思是轻薄浮躁就不能修养性情。节奏划分合理。</li>\n\t<li>D 选项：“非学 / 无以 / 广才”，意思是不学习就无法增长才干。节奏划分合理。</li>\n\t<li>所以选B</li>\n</ul>\n"}], "sequnce_number": 1, "description": "<div><p style=\"text-align: justify;\"><span>下面句子朗读节奏划分不正确的一项是</span><span>（</span><span style=\"color: #000000;\">　　</span><span>）</span></p></div>", "label": "", "title": "下面句子朗读节奏划分不正确的一项是（　　）", "res_type": "$RE0201", "adaptive": false, "timer": {"timer_type": "sequence"}, "time_dependent": false, "responses": [{"identifier": "RESPONSE_1-1", "sequence": "1-1", "base_type": "identifier", "cardinality": "single", "corrects": ["B"]}], "location": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/fc9426fd-8bfa-42e6-98fe-d8345bb0aa63@2.pkg/item.json?v=1752733178143", "lang": "", "items": [{"min_choice