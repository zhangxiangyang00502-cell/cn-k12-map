{"@class": "com.nd.elearning.sdk.resource.gateway.v5.bean.question.QuestionVo", "original_type": 4, "original_sub_type": "questions", "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "id": "7b73d3d2-890d-46c8-b9f8-675547ab15a0", "type": 201, "content": {"preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/7b73d3d2-890d-46c8-b9f8-675547ab15a0@4.pkg/1772595106706/mainbig.xml.jpg?v=1772595107625", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/7b73d3d2-890d-46c8-b9f8-675547ab15a0@4.pkg/1772595106706/mainbig.xml.jpg?v=1772595107625"}, "identifier": "7b73d3d2-890d-46c8-b9f8-675547ab15a0", "feedbacks": [{"identifier": "showHint", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": ""}, {"identifier": "showAnswer", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<p>联系上下文。</p>\n"}], "sequnce_number": 1, "description": "<p style=\"\">下列句子中，不能突出我们家的男子汉的风格的一项是（ ）</p>\n", "title": "下列句子中，不能突出我们家的男子汉的风格的一项是（ ）", "res_type": "$RE0201", "adaptive": false, "timer": {"timer_type": "sequence"}, "time_dependent": false, "responses": [{"identifier": "RESPONSE_1-1", "sequence": "1-1", "base_type": "identifier", "cardinality": "single", "corrects": ["D"]}], "location": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/7b73d3d2-890d-46c8-b9f8-675547ab15a0@4.pkg/item.json?v=1753265779397", "items": [{"min_choices": 0, "attachments": [], "columns": 1, "type": "choice", "choices_list": [], "associable_hotspots": [], "children": [], "hide_answer_area": false, "options": [], "orientation": 0, "multiple": false, "raw": false, "titles": [], "rows": 1, "response_identifier": "RESPONSE_1-1", "sequence": "0", "max_choices": 1, "gap_imgs": [], "choice_type": "character", "shuffle": false, "choices": [{"identifier": "A", "correct": false, "match_max": 1, "group_id": "", "fixed": false, "text": "<p style=\"\">他吃饭吃得很好，量很多，范围很广——什么都要吃。</p>\n"}, {"identifier": "B", "correct": false, "match_max": 1, "group_id": "", "fixed": false, "text": "<p style=\"\">他好久没说话，潦草地吃着山楂片，神情有些沮丧。</p>\n"}, {"identifier": "C", "correct": false, "match_max": 1, "group_id": "", "fixed": false, "text": "<p style=\"\">后来，他会自个儿拿着五个汽水瓶和一元钱到门口小店换橘子水了。他是一定要自己去的。假如我不放心，跟在他后面，他便停下脚步不走了:“你回去，回去嘛!”</p>\n"}, {"identifier": "D", "correct": false, "match_max": 1, "group_id": "", "fixed": true, "text": "<p>他喜欢哭。</p>\n"}], "prompt": "<p style=\"\">下列句子中，不能突出我们家的男子汉的风格的一项是（ ）</p>\n", "object": {"data": "", "width": "1000", "type": "image/png", "params": {"originalImage": "", "blankImage": ""}, "height": "600"}}], "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878"}, "source": {"container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "tags": ["$M002000000", "44bee8bc-54e6-11ed-9c34-850ba61fa9f4", "6a749654-0772-11ed-ac74-092ab92074e6", "e7bbd3ea-0590-11ed-9c79-92fc3b3249d5", "ff8080814371757b014390fcdce504bd", "$RE0000", "$M003002000", "$RE0200", "5036342748", "44beb9aa-54e6-11ed-9c34-850ba61fa9f4", "$RE0201", "44bee8bc-54e6-11ed-9c34-850ba61fa9f4", "6a749654-0772-11ed-ac74-092ab92074e6", "e7bbd3ea-0590-11ed-9c79-92fc3b3249d5", "ff8080814371757b014390fcdce504bd", "44beb9aa-54e6-11ed-9c34-850ba61fa9f4"], "status": "ONLINE", "is_publish": false, "id": "7b73d3d2-890d-46c8-b9f8-675547ab15a0", "global_title": {"zh-CN": "下列句子中，不能突出我们家的男子汉的风格的一项是（ ）"}, "global_description": {"zh-CN": "<p style=\"\">下列句子中，不能突出我们家的男子汉的风格的一项是（ ）</p>\n"}, "global_keywords": {}, "global_label": {}, "custom_properties": {"sys_packing_status": "ready", "preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/7b73d3d2-890d-46c8-b9f8-675547ab15a0@4.pkg/1772595106706/mainbig.xml.jpg?v=1772595107625", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/7b73d3d2-890d-46c8-b9f8-675547ab15a0@4.pkg/1772595106706/mainbig.xml.jpg?v=1772595107625"}, "auto_fill_thum