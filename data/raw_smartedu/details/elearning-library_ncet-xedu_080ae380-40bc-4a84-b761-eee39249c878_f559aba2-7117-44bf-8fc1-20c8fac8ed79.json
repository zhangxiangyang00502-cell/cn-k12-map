{"@class": "com.nd.elearning.sdk.resource.gateway.v5.bean.question.QuestionVo", "original_type": 4, "original_sub_type": "questions", "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "id": "f559aba2-7117-44bf-8fc1-20c8fac8ed79", "type": 201, "content": {"preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/f559aba2-7117-44bf-8fc1-20c8fac8ed79@3.pkg/1772595150075/mainbig.xml.jpg?v=1772595150826", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/f559aba2-7117-44bf-8fc1-20c8fac8ed79@3.pkg/1772595150075/mainbig.xml.jpg?v=1772595150826"}, "identifier": "f559aba2-7117-44bf-8fc1-20c8fac8ed79", "feedbacks": [{"identifier": "showHint", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": ""}, {"identifier": "showAnswer", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<p>D运用拟人修辞</p>\n"}], "sequnce_number": 1, "description": "<p><strong>下列句子中，没有运用比喻的修辞手法的一项是（</strong><strong>&nbsp;&nbsp;&nbsp;）</strong></p>\n", "title": "下列句子中，没有运用比喻的修辞手法的一项是（   ）", "res_type": "$RE0201", "adaptive": false, "timer": {"timer_type": "sequence"}, "time_dependent": false, "responses": [{"identifier": "RESPONSE_1-1", "sequence": "1-1", "base_type": "identifier", "cardinality": "single", "corrects": ["D"]}], "location": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/f559aba2-7117-44bf-8fc1-20c8fac8ed79@3.pkg/item.json?v=1753260596016", "items": [{"min_choices": 0, "attachments": [], "columns": 1, "type": "choice", "choices_list": [], "associable_hotspots": [], "children": [], "hide_answer_area": false, "options": [], "orientation": 0, "multiple": false, "raw": false, "titles": [], "rows": 1, "response_identifier": "RESPONSE_1-1", "sequence": "0", "max_choices": 1, "gap_imgs": [], "choice_type": "character", "shuffle": false, "choices": [{"identifier": "A", "correct": false, "match_max": 1, "group_id": "", "fixed": false, "text": "<p style=\"\">在海的远处，水是那么蓝，像最美丽的矢车菊花瓣；又是那么清，像最明亮的玻璃。</p>\n"}, {"identifier": "B", "correct": false, "match_max": 1, "group_id": "", "fixed": false, "text": "<p style=\"\">鱼儿们在这些枝叶中间游来游去，像是天空中的飞鸟。</p>\n"}, {"identifier": "C", "correct": false, "match_max": 1, "group_id": "", "fixed": false, "text": "<p style=\"\">她的眼睛是蔚蓝色的，像最深的湖水。</p>\n"}, {"identifier": "D", "correct": false, "match_max": 1, "group_id": "", "fixed": true, "text": "<p>树根和树顶看起来好像在做着亲昵的游戏。</p>\n"}], "prompt": "<p><strong>下列句子中，没有运用比喻的修辞手法的一项是（</strong><strong>&nbsp;&nbsp;&nbsp;）</strong></p>\n", "object": {"data": "", "width": "1000", "type": "image/png", "params": {"originalImage": "", "blankImage": ""}, "height": "600"}}], "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878"}, "source": {"container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "tags": ["$M002000000", "44bee8bc-54e6-11ed-9c34-850ba61fa9f4", "6a749654-0772-11ed-ac74-092ab92074e6", "e7bbd3ea-0590-11ed-9c79-92fc3b3249d5", "ff8080814371757b014390fcdce504bd", "$RE0000", "$M003002000", "$RE0200", "5036342748", "44beb9aa-54e6-11ed-9c34-850ba61fa9f4", "$RE0201", "44bee8bc-54e6-11ed-9c34-850ba61fa9f4", "6a749654-0772-11ed-ac74-092ab92074e6", "e7bbd3ea-0590-11ed-9c79-92fc3b3249d5", "ff8080814371757b014390fcdce504bd", "44beb9aa-54e6-11ed-9c34-850ba61fa9f4"], "status": "ONLINE", "is_publish": false, "id": "f559aba2-7117-44bf-8fc1-20c8fac8ed79", "global_title": {"zh-CN": "下列句子中，没有运用比喻的修辞手法的一项是（   ）"}, "global_description": {"zh-CN": "<p><strong>下列句子中，没有运用比喻的修辞手法的一项是（</strong><strong>&nbsp;&nbsp;&nbsp;）</strong></p>\n"}, "global_keywords": {}, "global_label": {}, "custom_properties": {"sys_packing_status": "ready", "preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/f559aba2-7117-44bf-8fc1-20c8fac8ed79@3.pkg/1772595150075/mainbig.xml.jpg?v=1772595150826", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/f559aba2-7117-44bf-8fc1-2