{"@class": "com.nd.elearning.sdk.resource.gateway.v5.bean.question.QuestionVo", "original_type": 4, "original_sub_type": "questions", "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "id": "0704d402-3248-455a-b7d6-cce2a2d3cad0", "type": 201, "content": {"preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/0704d402-3248-455a-b7d6-cce2a2d3cad0@1.pkg/1772597526414/mainbig.xml.jpg?v=1772597527307", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/0704d402-3248-455a-b7d6-cce2a2d3cad0@1.pkg/1772597526414/mainbig.xml.jpg?v=1772597527307"}, "identifier": "0704d402-3248-455a-b7d6-cce2a2d3cad0", "feedbacks": [{"identifier": "showHint", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": ""}, {"identifier": "showAnswer", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<p align=\"justify\">该题考查公民政治权利的正确行使。</p>\n\n<p align=\"justify\">A：我国宪法规定，选举权和被选举权需年满18周岁，小李未满18周岁，无权参加人大代表选举，故A错误。</p>\n\n<p align=\"justify\">B：向学校反映食堂卫生问题属于对教育机构的建议，不涉及公民政治权利（监督权针对国家机关及其工作人员），故B不符合题意。</p>\n\n<p align=\"justify\">C：游行示威需依法申请批准，擅自组织违反法律规定，故C错误。</p>\n\n<p align=\"justify\">D：拨打市政热线反映国家机关工作人员问题，是依法行使监督权的表现，故D正确。</p>\n\n<p align=\"justify\">故本题选D。</p>\n"}], "sequnce_number": 1, "description": "<p align=\"justify\">（改编）. 下列做法属于正确行使公民政治权利的是（ &nbsp;&nbsp;&nbsp;&nbsp;）</p>\n", "title": "（改编）. 下列做法属于正确行使公民政治权利的是（     ）", "res_type": "$RE0201", "adaptive": false, "timer": {"timer_type": "sequence"}, "time_dependent": false, "responses": [{"identifier": "RESPONSE_1-1", "sequence": "1-1", "base_type": "identifier", "cardinality": "single", "corrects": ["D"]}], "location": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/0704d402-3248-455a-b7d6-cce2a2d3cad0@1.pkg/item.json?v=1755140761699", "items": [{"min_choices": 0, "attachments": [], "columns": 1, "type": "choice", "choices_list": [], "associable_hotspots": [], "children": [], "hid