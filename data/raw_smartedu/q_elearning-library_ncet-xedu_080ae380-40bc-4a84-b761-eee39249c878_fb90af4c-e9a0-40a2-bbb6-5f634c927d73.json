{"@class": "com.nd.elearning.sdk.resource.gateway.v5.bean.question.QuestionVo", "original_type": 4, "original_sub_type": "questions", "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "id": "fb90af4c-e9a0-40a2-bbb6-5f634c927d73", "type": 201, "content": {"answer_steps": [], "preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/fb90af4c-e9a0-40a2-bbb6-5f634c927d73@1.pkg/1772597669260/mainbig.xml.jpg?v=1772597669912", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/fb90af4c-e9a0-40a2-bbb6-5f634c927d73@1.pkg/1772597669260/mainbig.xml.jpg?v=1772597669912"}, "identifier": "fb90af4c-e9a0-40a2-bbb6-5f634c927d73", "test_cases": "", "feedbacks": [{"identifier": "showAnswer", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<div><p style=\"background: #FFFFFF;text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">本题考查生命的传承。</span></p><p style=\"background: #FFFFFF;text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">A：</span><span style=\"background: #FFFFFF;color: #404040;\">雷锋</span><span style=\"background: #FFFFFF;color: #404040;\">留下的精神财富影响着一代又一代人，说明人的精神生命是不断传承的，在传承中积淀和丰富，故A说法正确；</span></p><p style=\"background: #FFFFFF;text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">B：任何人都无法打破生命发展的自然规律，人的生命是有限的，故B说法错误；</span></p><p style=\"background: #FFFFFF;text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">C：能为社会做贡献的生命，就是有意义的，故C说法错误；</span></p><p style=\"background: #FFFFFF;text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">D：人的身体生命是无法永恒的，故D说法错误；</span></p><p style=\"text-align: justify;\"><span style=\"background: #FFFFFF;color: #404040;\">故本题选A。</span></p></div>"}, {"identifier": "showHint", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": ""}], "sequnce_number": 1, "description": "<div><p style=\"text-al