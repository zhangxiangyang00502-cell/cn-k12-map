{"@class": "com.nd.elearning.sdk.resource.gateway.v5.bean.question.QuestionVo", "original_type": 4, "original_sub_type": "questions", "container_id": "elearning-library_ncet-xedu_080ae380-40bc-4a84-b761-eee39249c878", "id": "0cfab084-3904-4487-885a-c86eaa8b13b4", "type": 201, "content": {"preview": {"question_big": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/0cfab084-3904-4487-885a-c86eaa8b13b4@1.pkg/1772597693196/mainbig.xml.jpg?v=1772597694016", "question_small": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/0cfab084-3904-4487-885a-c86eaa8b13b4@1.pkg/1772597693196/mainbig.xml.jpg?v=1772597694016"}, "identifier": "0cfab084-3904-4487-885a-c86eaa8b13b4", "feedbacks": [{"identifier": "showHint", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<p>本题考查增强安全意识</p>\n"}, {"identifier": "showAnswer", "sequence": "1", "outcome_identifier": "FEEDBACK", "show_hide": "show", "content": "<p align=\"justify\">A：溺水是未成年人非正常死亡的重要原因，警示青少年牢固树立安全意识，警惕意外伤害，增强风险意识，提高危险预判能力，故A符合题意；</p>\n\n<p align=\"justify\">B：提高游泳技术未必会杜绝溺水，故B说法错误；</p>\n\n<p align=\"justify\">C：游泳运动有利于身体健康，不能远离，故C说法错误；</p>\n\n<p align=\"justify\">D：邀约同学一起野泳存在安全隐患。</p>\n\n<p align=\"justify\">故本题选A。</p>\n"}], "sequnce_number": 1, "description": "<p align=\"justify\">（改编）快乐暑假，安全同行；珍爱生命，预防溺水。相关数据显示，我国每年约有5.9万人死于溺水，溺水是未成年人非正常死亡的重要原因。这警示青少年（&nbsp;&nbsp;&nbsp;）</p>\n", "title": "（改编）快乐暑假，安全同行；珍爱生命，预防溺水。相关数据显示，我国每年约有5.9万人死于溺水，溺水是未成年人非正常死亡的重要原因。这警示青少年（   ）", "res_type": "$RE0201", "adaptive": false, "timer": {"timer_type": "sequence"}, "time_dependent": false, "responses": [{"identifier": "RESPONSE_1-1", "sequence": "1-1", "base_type": "identifier", "cardinality": "single", "corrects": ["A"]}], "location": "https://r1-ndr.ykt.cbern.com.cn/edu_product/esp/questions/0cfab084-3904-4487-885a-c86eaa8b13b4@1.pkg/item.json?v=1754969456306", "items": [{"min_choices": 0, "attachments": [], "columns": 1, "type": "choice", "choices_list": [], "associable_hotspots": [], "childre